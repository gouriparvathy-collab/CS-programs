#include <stdio.h>
#include <math.h>
int factorial(int n)
{
    int i;
    int fact = 1;
    for(i = 1; i <= n; i++)
    {
        fact = fact * i;
    }

    return fact;
}

int main()
{
    float x, sinx = 0, cosx = 0, term;
    float sum = 0;
    int i, sign = 1;

    printf("Enter value of x: ");
    scanf("%f", &x);

    for(i = 1; i <= 15; i = i + 2)
    {
        term = sign * (pow(x, i) / factorial(i));
        sinx = sinx + term;
        sign = -sign;
    }
    printf("sin(x) = %f\n", sinx);

    sign = 1;

    for(i = 0; i <= 14; i = i + 2)
    {
        term = sign * (pow(x, i) / factorial(i));
        cosx = cosx + term;
        sign = -sign;
    }
    printf("cos(x) = %f\n", cosx);

    for(i = 1; i <= 10; i++)
    {
        sum = sum + pow((1.0/i), i);
    }

    printf("SUM = %f\n", sum);

    return 0;
}
